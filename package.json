  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
